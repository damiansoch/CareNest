# ─── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=carenest
DB_USER=carenest
DB_PASSWORD=carenest_dev_password
DB_HOST=db
DB_PORT=5432

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@carenest.app

# Production SMTP (fill when EMAIL_BACKEND=smtp):
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
FRONTEND_URL=http://localhost:3000
# Public site URL used for SEO: canonical URLs, sitemap, OG tags
# Set this to your production domain in Render/production environment
NEXT_PUBLIC_SITE_URL=https://carenest.app
